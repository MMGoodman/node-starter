{
  "name": "recording-uploader",
  "version": "1.0.0",
  "description": "Screen recording chunk uploader with resilient upload",
"scripts": {
    "build": "tsc --project tsconfig.client.json",
    "mock-server": "ts-node mock-server.ts",
    "test": "jest",
    "start": "npm run build && npm run mock-server"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "fake-indexeddb": "^6.2.5",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
