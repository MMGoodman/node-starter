{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node", "jest"],
    "lib": ["ES2020", "DOM"]
  },
  "include": ["mock-server.ts", "src/**/*.ts", "tests/**/*.ts"]
}